{
    "permissions": {
        "allow": [
            "Read(./**)",
            "Edit(./**)",
            "Write(./**)",
            "Glob(./**)",
            "Grep(./**)",
            "Bash(bd:*)"
        ],
        "deny": [
            "Read(./.env)",
            "Read(./.env.*)",
            "Read(./secrets/**)",
            "Bash(rm -rf:*)",
            "Bash(sudo:*)",
            "Bash(git commit --no-verify:*)",
            "Bash(bd reset:*)",
            "Bash(bd delete:*)",
            "Bash(bd admin cleanup:*)",
            "Bash(bd admin compact:*)",
            "Bash(bd purge:*)",
            "Bash(bd gc:*)"
        ]
    },
    "hooks": {
        "SessionStart": [
            {
                "matcher": "",
                "hooks": [
                    {
                        "type": "command",
                        "command": "bd prime"
                    }
                ]
            }
        ],
        "PreCompact": [
            {
                "matcher": "",
                "hooks": [
                    {
                        "type": "command",
                        "command": "bd prime"
                    }
                ]
            }
        ]
    }
}
